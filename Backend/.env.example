# MediConnect Backend Environment Variables
# Copy this file to .env and fill in your values

# ==================== SERVER ====================
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
NAME=MediConnect
VERSION=1.0.0

# ==================== DATABASE ====================
MONGODB_URL=mongodb://localhost:27017/mediconnect

# ==================== JWT ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ==================== CLOUDINARY (Optional) ====================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==================== FRONTEND ====================
FRONTEND_URL=http://localhost:5173

# ==================== KHALTI PAYMENT ====================
KHALTI_SECRET_KEY=your-khalti-secret-key-here
KHALTI_PUBLIC_KEY=your-khalti-public-key-here
KHALTI_API_BASE_URL=https://dev.khalti.com/api/v2
