# MediConnect Backend Environment Variables
# Copy this file to .env and fill in your values

# ==================== SERVER ====================
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
NAME=MediConnect
VERSION=1.0.0

# ==================== DATABASE ====================
MONGODB_URL=mongodb://localhost:27017/mediconnect

# ==================== JWT ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ==================== CLOUDINARY (Optional) ====================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==================== FRONTEND ====================
FRONTEND_URL=http://localhost:5173

# ==================== KHALTI PAYMENT ====================
KHALTI_SECRET_KEY=your-khalti-secret-key-here
KHALTI_PUBLIC_KEY=your-khalti-public-key-here
KHALTI_API_BASE_URL=https://dev.khalti.com/api/v2

# ==================== EMAIL (Resend) ====================
# Required if you want booking and system emails.
RESEND_API_KEY=
# Use a verified sender in Resend, e.g. MediConnect <noreply@yourdomain.com>
EMAIL_FROM=MediConnect <noreply@mediconnect.local>

# ==================== SOCIAL OAUTH (Patient flow) ====================
# Create OAuth apps and configure redirect URIs as:
# {FRONTEND_URL}{OAUTH_CALLBACK_PATH}/{provider}
# Example: http://localhost:5173/auth/oauth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Optional feature toggles (true/false). Provider must also have client keys.
# Google-first default:
GOOGLE_AUTH_ENABLED=true
GITHUB_AUTH_ENABLED=false
FACEBOOK_AUTH_ENABLED=false

# Frontend callback route used after OAuth provider redirects back.
OAUTH_CALLBACK_PATH=/auth/oauth/callback
